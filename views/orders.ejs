<!DOCTYPE html>
<html>
<head>
  <title>Orders</title>
<link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

</head>

<body>
<!-- TOAST -->

<% if (success) { %>

<div class="toast-container position-fixed top-0 end-0 p-3">

  <div id="liveToast"
       class="toast show align-items-center text-bg-success border-0"
       role="alert">

    <div class="d-flex">

      <div class="toast-body">
        <%= success %>
      </div>

      <button type="button"
              class="btn-close btn-close-white me-2 m-auto"
              data-bs-dismiss="toast">
      </button>

    </div>

  </div>

</div>

<% } %>  
<nav class="navbar navbar-expand-lg custom-navbar">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">🌾 AgroLink</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNavbar">
      <div class="navbar-nav ms-auto nav-buttons">

        <a href="/" class="nav-link">Home</a>

        <% if (user) { %>
          <span class="nav-user">Hi, <%= user.username %> (<%= user.role %>)</span>

          <% if (user.role === "farmer") { %>
            <a href="/dashboard" class="nav-link">Dashboard</a>
            <a href="/add" class="nav-link">Add Product</a>
            <a href="/manage-orders" class="nav-link">Manage Orders</a>
          <% } %>

          <% if (user.role === "user") { %>
            <a href="/orders" class="nav-link">My Orders</a>
          <% } %>

          <a href="/logout" class="nav-link logout-link">Logout</a>
        <% } else { %>
          <a href="/login" class="nav-link">Login</a>
          <a href="/register" class="nav-link register-link">Register</a>
        <% } %>

      </div>
    </div>
  </div>
</nav>

<div class="container mt-4">

  <h2 class="text-center mb-4">📦 My Orders</h2>

  <table class="table table-bordered shadow">

    <tr>
      <th>Product</th>
      <th>Price</th>
      <th>Quantity</th>
      <th>Status</th>
      <th>Action</th>
      

    </tr>

    <% orders.forEach(o => { %>

      <tr>
        <td><%= o.productName %></td>
        <td>₹<%= o.price %></td>
        <td><%= o.quantity %></td>
        <td>

          <% if (o.status === "Pending") { %>
            <span class="badge bg-warning text-dark">
              Pending
            </span>
          <% } %>

          <% if (o.status === "Shipped") { %>
            <span class="badge bg-primary">
              Shipped
            </span>
          <% } %>

          <% if (o.status === "Delivered") { %>
            <span class="badge bg-success">
              Delivered
            </span>
          <% } %>

        </td>
        <td>
          <% if (user && user.role === "user" && o.status === "Pending") { %>
            <a href="/cancel-order/<%= o._id %>" 
              class="btn btn-danger btn-sm"
                onclick="return confirm('Are you sure you want to cancel this order?')">
                Cancel
            </a>
          <% } else if (o.status === "Cancelled") { %>
              <span class="badge bg-danger">Cancelled</span>
          <% } else { %>
            <span class="text-muted">Not allowed</span>
          <% } %>
        </td>
         <td><%= o.paymentMethod %></td>
  <td>
  <% if (o.paymentStatus === "Paid") { %>
    <span class="badge bg-success">Paid</span>
  <% } else { %>
    <span class="badge bg-warning text-dark">Pending</span>
  <% } %>
  </td>
   

    <td><%= o.paymentMethod %></td>
 <% }) %>

      </tr>
      

  </table>

</div>
<!-- FOOTER -->

<footer class="footer mt-5">

  <div class="container">

    <div class="row">

      <!-- About -->

      <div class="col-md-4 mb-3">
        <h5>🌾 AgroLink</h5>

        <p>
          Connecting farmers directly with consumers through a smart digital marketplace.
        </p>
      </div>

      <!-- Quick Links -->

      <div class="col-md-4 mb-3">

        <h5>Quick Links</h5>

        <ul class="list-unstyled">

          <li><a href="/">Home</a></li>

          <% if (user && user.role === "farmer") { %>
            <li><a href="/dashboard">Dashboard</a></li>
          <% } %>

          <% if (user && user.role === "user") { %>
            <li><a href="/orders">My Orders</a></li>
          <% } %>

          <li><a href="/login">Login</a></li>

        </ul>
      </div>

      <!-- Contact -->

      <div class="col-md-4 mb-3">

        <h5>Contact</h5>

        <p>📍 India</p>
        <p>📧 agrolink@gmail.com</p>
        <p>📞 +91 9876543210</p>

      </div>

    </div>

    <hr>

    <p class="text-center mb-0">
      © 2026 AgroLink. All Rights Reserved.
    </p>

  </div>

</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>