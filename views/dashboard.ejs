<!DOCTYPE html>
<html>
<head>
  <title>Farmer Dashboard</title>
  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<!-- TOAST -->

<% if (success) { %>

<div class="toast-container position-fixed top-0 end-0 p-3">

  <div id="liveToast"
       class="toast show align-items-center text-bg-success border-0"
       role="alert">

    <div class="d-flex">

      <div class="toast-body">
        <%= success %>
      </div>

      <button type="button"
              class="btn-close btn-close-white me-2 m-auto"
              data-bs-dismiss="toast">
      </button>

    </div>

  </div>

</div>

<% } %>  
<nav class="navbar navbar-expand-lg custom-navbar">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">🌾 AgroLink</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNavbar">
      <div class="navbar-nav ms-auto nav-buttons">

        <a href="/" class="nav-link">Home</a>

        <% if (user) { %>
          <span class="nav-user">Hi, <%= user.username %> (<%= user.role %>)</span>

          <% if (user.role === "farmer") { %>
            <a href="/dashboard" class="nav-link">Dashboard</a>
            <a href="/add" class="nav-link">Add Product</a>
            <a href="/manage-orders" class="nav-link">Manage Orders</a>
          <% } %>

          <% if (user.role === "user") { %>
            <a href="/orders" class="nav-link">My Orders</a>
          <% } %>

          <a href="/logout" class="nav-link logout-link">Logout</a>
        <% } else { %>
          <a href="/login" class="nav-link">Login</a>
          <a href="/register" class="nav-link register-link">Register</a>
        <% } %>

      </div>
    </div>
  </div>
</nav>

<div class="container mt-4">

  <h2 class="text-center">👨‍🌾 My Products</h2>

  <a href="/add" class="btn btn-success mb-3">Add New Product</a>

  <div class="row">

    <% products.forEach(p => { %>

      <div class="col-md-4">
        <div class="card p-3 mb-4 shadow">

          <img src="/uploads/<%= p.image %>" class="img-fluid mb-2"
               style="height:200px; object-fit:cover;">

          <h5><%= p.name %></h5>
          <p>₹<%= p.price %></p>

          <a href="/delete/<%= p._id %>" 
             class="btn btn-danger"
             onclick="return confirm('Delete this product?')">
             Delete
          </a>
            <a href="/edit/<%= p._id %>" class="btn btn-primary mb-2">
             Edit
            </a>
        </div>
      </div>

    <% }) %>

  </div>

</div>
<!-- FOOTER -->

<footer class="footer mt-5">

  <div class="container">

    <div class="row">

      <!-- About -->

      <div class="col-md-4 mb-3">
        <h5>🌾 AgroLink</h5>

        <p>
          Connecting farmers directly with consumers through a smart digital marketplace.
        </p>
      </div>

      <!-- Quick Links -->

      <div class="col-md-4 mb-3">

        <h5>Quick Links</h5>

        <ul class="list-unstyled">

          <li><a href="/">Home</a></li>

          <% if (user && user.role === "farmer") { %>
            <li><a href="/dashboard">Dashboard</a></li>
          <% } %>

          <% if (user && user.role === "user") { %>
            <li><a href="/orders">My Orders</a></li>
          <% } %>

          <li><a href="/login">Login</a></li>

        </ul>
      </div>

      <!-- Contact -->

      <div class="col-md-4 mb-3">

        <h5>Contact</h5>

        <p>📍 India</p>
        <p>📧 agrolink@gmail.com</p>
        <p>📞 +91 9876543210</p>

      </div>

    </div>

    <hr>

    <p class="text-center mb-0">
      © 2026 AgroLink. All Rights Reserved.
    </p>

  </div>

</footer>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>