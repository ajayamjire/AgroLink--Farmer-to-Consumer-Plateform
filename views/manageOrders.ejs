<!DOCTYPE html>
<html>
<head>
  <title>Manage Orders</title>
<link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
</head>

<body>

    <nav class="navbar navbar-expand-lg custom-navbar">
  <div class="container-fluid">
    <a class="navbar-brand" href="/">🌾 AgroLink</a>

    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
      <span class="navbar-toggler-icon"></span>
    </button>

    <div class="collapse navbar-collapse" id="mainNavbar">
      <div class="navbar-nav ms-auto nav-buttons">

        <a href="/" class="nav-link">Home</a>

        <% if (user) { %>
          <span class="nav-user">Hi, <%= user.username %> (<%= user.role %>)</span>

          <% if (user.role === "farmer") { %>
            <a href="/dashboard" class="nav-link">Dashboard</a>
            <a href="/add" class="nav-link">Add Product</a>
            <a href="/manage-orders" class="nav-link">Manage Orders</a>
          <% } %>

          <% if (user.role === "user") { %>
            <a href="/orders" class="nav-link">My Orders</a>
          <% } %>

          <a href="/logout" class="nav-link logout-link">Logout</a>
        <% } else { %>
          <a href="/login" class="nav-link">Login</a>
          <a href="/register" class="nav-link register-link">Register</a>
        <% } %>

      </div>
    </div>
  </div>
</nav>

<div class="container mt-4">

  <h2 class="text-center mb-4">📦 Manage Orders</h2>

  <table class="table table-bordered shadow">

    <tr>
      <th>Product</th>
      <th>Status</th>
      <th>Action</th>
      <th>Customer</th>
      <th>Address</th>
      <th>Mobile</th>
    </tr>

    <% orders.forEach(o => { %>

      <tr>

        <td><%= o.productName %></td>

        <td><%= o.status %></td>

        <td>

          <a href="/status/<%= o._id %>/Shipped" 
             class="btn btn-primary btn-sm">
             Ship
          </a>

          <a href="/status/<%= o._id %>/Delivered" 
             class="btn btn-success btn-sm">
             Deliver
          </a>

        </td>
        <td><%= o.username %></td>
        <td><%= o.deliveryAddress %></td>
        <td><%= o.mobileNumber %></td>
          <td>
  <% if (o.latitude && o.longitude) { %>
    <a 
      href="/track-order/<%= o._id %>" 
      class="btn btn-info btn-sm">
      View Map
    </a>
  <% } else { %>
    No location
  <% } %>
</td>
      </tr>

    <% }) %>

  </table>

</div>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>