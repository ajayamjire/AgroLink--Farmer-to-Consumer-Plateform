<!DOCTYPE html>
<html>
<head>
  <title>Checkout</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <link rel="stylesheet" href="/css/style.css">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body>

<div class="container mt-5">
  <div class="card p-4 shadow mx-auto" style="max-width:550px;">

    <h3 class="text-center mb-4">🛒 Checkout</h3>

    <h5><%= product.name %></h5>
    <p>Price: ₹<%= product.price %></p>
    <p>Available Quantity: <%= product.quantity %></p>
    <p>Farmer: <%= product.farmerName %></p>

    <form action="/place-order/<%= product._id %>" method="POST">

      <label class="form-label">Quantity</label>
      <input 
        type="number"
        name="quantity"
        class="form-control mb-3"
        min="1"
        max="<%= product.quantity %>"
        value="1"
        required
      >

      <label class="form-label">Delivery Address</label>
      <textarea 
        name="deliveryAddress"
        class="form-control mb-3"
        placeholder="Enter full delivery address"
        required></textarea>

      <label class="form-label">Mobile Number</label>
      <input 
        type="tel"
        name="mobileNumber"
        class="form-control mb-3"
        placeholder="Enter 10-digit mobile number"
        pattern="[6-9][0-9]{9}"
        maxlength="10"
        minlength="10"
        required
      >

      <input type="hidden" name="latitude" id="latitude">
      <input type="hidden" name="longitude" id="longitude">

      <button type="button" class="btn btn-outline-success w-100 mb-3" onclick="getLocation()">
        📍 Use My Current Location
      </button>

      <p id="locationText" class="text-success"></p>

      <label class="form-label">Payment Method</label>
      <select name="paymentMethod" id="paymentMethod" class="form-control mb-3" required>
        <option value="Cash on Delivery">Cash on Delivery</option>
        <option value="UPI Payment">UPI Payment</option>
      </select>

      <div id="upiSection" style="display:none;" class="card p-3 text-center mb-3">

        <h5>📱 Scan & Pay</h5>

        <img 
          src="/uploads/upi-qr.png.jpeg"
          class="img-fluid mx-auto mb-3"
          style="max-width:250px;"
        >

        <p class="text-success">
          Scan QR using Google Pay / PhonePe / Paytm
        </p>

        <input 
          type="text"
          name="transactionId"
          id="transactionId"
          class="form-control mb-2"
          placeholder="Enter UPI Transaction ID"
        >
        <button 
  type="button"
  class="btn btn-success w-100 mt-2"
  id="verifyBtn"
>
  Verify Payment
</button>
        <small class="text-muted">
          After payment, enter transaction ID and place order.
        </small>

      </div>
        <div 
      id="paymentSuccess"
      class="alert alert-success mt-3"
    style="display:none;"
      >
      ✅ Payment Successful
      </div>
      <button class="btn btn-success w-100">
        Place Order
      </button>
        
    </form>

  </div>
</div>

<script>
  const paymentMethod = document.getElementById("paymentMethod");
  const upiSection = document.getElementById("upiSection");
  const transactionId = document.getElementById("transactionId");

  paymentMethod.addEventListener("change", () => {
    if (paymentMethod.value === "UPI Payment") {
      upiSection.style.display = "block";
      transactionId.required = true;
    } else {
      upiSection.style.display = "none";
      transactionId.required = false;
    }
  });

  function getLocation() {
    if (navigator.geolocation) {
      navigator.geolocation.getCurrentPosition((position) => {
        document.getElementById("latitude").value = position.coords.latitude;
        document.getElementById("longitude").value = position.coords.longitude;
        document.getElementById("locationText").innerText = "Location added successfully!";
      });
    } else {
      alert("Geolocation is not supported");
    }
  }
</script>
